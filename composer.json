{
    "name": "yii2-starter-kit/yii2-starter-kit",
    "description": "Yii2 Starter Kit Application Template",
    "keywords": [
        "dtsmart"
    ],
    "authors": [
        {
            "name": "Khuongdev2001",
            "email": "khuongnh@dtsmart.vn",
            "homepage": "https://terentev.net"
        }
    ],
    "type": "project",
    "license": "BSD-3-Clause",
    "support": {
        "issues": "https://github.com/yii2-starter-kit/yii2-starter-kit/issues?state=open",
        "source": "https://github.com/yii2-starter-kit/yii2-starter-kit"
    },
    "require": {
        "php": ">=7.2",
        "yiisoft/yii2": "~2.0.46",
        "trntv/yii2-command-bus": "^3.0",
        "intervention/image": "^2.1",
        "vlucas/phpdotenv": "^5.4",
        "symfony/process": "^4.0",
        "schmunk42/yii2-giiant": "*",
        "hashids/hashids": "^4.0",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-gd": "*",
        "ext-openssl": "*",
        "phpoffice/phpspreadsheet": "^1.23",
        "sam-it/yii2-jsonbehavior": "v1.0.5",
        "yii2tech/ar-softdelete": "*",
        "sentry/sdk": "^3.2",
        "yiisoft/yii2-httpclient": "^2.0",
        "yii2-starter-kit/yii2-file-kit": "^2.1",
        "league/flysystem-aws-s3-v3": "^1.0@dev",
        "picqer/php-barcode-generator": "^2.2",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "yiisoft/yii2-debug": "^2.0.0",
        "yiisoft/yii2-gii": "^2.0.0",
        "yiisoft/yii2-faker": "^2.0.0"
    },
    "autoload-dev": {
        "psr-4": {
            "tests\\": "tests/"
        }
    },
    "suggest": {
        "trntv/yii2-debug-xhprof": "dev-master@dev"
    },
    "config": {
        "process-timeout": 1800,
        "optimize-autoloader": true,
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "php-http/discovery": true
        }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "archive": {
        "exclude": [
            "docs"
        ]
    },
    "scripts": {
        "build:env": [
            "cp .env.dist .env"
        ],
        "build:app": [
            "@composer install",
            "echo 'waiting for mysql' && sleep 10",
            "console/yii app/setup --interactive=0"
        ],
        "docker:build": [
            "@build:env",
            "@docker:start",
            "docker-compose exec -T app composer run-script build:app",
            "docker-compose run -T --rm webpacker npm i npm@latest -g",
            "docker-compose run -T --rm webpacker npm install",
            "docker-compose run -T --rm webpacker npm run build",
            "echo \"All ok!\""
        ],
        "docker:start": [
            "docker-compose up --force-recreate -d"
        ],
        "docker:cleanup": [
            "docker-compose rm -fsv"
        ]
    }
}
